---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  admin?: boolean;
}

const {
  title,
  description = 'Reusable Git-backed CMS platform built with Astro.',
  admin = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class:list={{ 'admin-body': admin }}>
    <nav aria-label="Skip navigation"><a class="skip-link" href="#main-content">Skip to main content</a></nav>
    <slot />
  </body>
</html>
