---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  admin?: boolean;
  canonical?: string;
  locale?: string;
  socialImage?: string;
  socialImageAlt?: string;
  noIndex?: boolean;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = 'Reusable Git-backed CMS platform built with Astro.',
  admin = false,
  canonical,
  locale = 'en',
  socialImage,
  socialImageAlt = '',
  noIndex = false,
  structuredData,
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {(admin || noIndex) && <meta name="robots" content="noindex, nofollow" />}
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="sitemap" href="/sitemap.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {socialImage && <meta property="og:image" content={socialImage} />}
    {socialImage && <meta property="og:image:alt" content={socialImageAlt} />}
    <meta name="twitter:card" content={socialImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    {socialImage && <meta name="twitter:image:alt" content={socialImageAlt} />}
    {structuredData && <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData).replace(/</g, '\\u003c')} />}
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class:list={{ 'admin-body': admin }}>
    <nav aria-label="Skip navigation"><a class="skip-link" href="#main-content">Skip to main content</a></nav>
    <slot />
  </body>
</html>
