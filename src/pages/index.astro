---
import BlockRenderer from '../components/blocks/BlockRenderer.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import { loadHomePage, loadNavigation, loadSiteSettings } from '../services/page-loader';

const [page, settings, navigation] = await Promise.all([loadHomePage(), loadSiteSettings(), loadNavigation()]);
const title = `${page.seo.title || page.title} · ${settings.defaultSeo.titleSuffix}`;
const description = page.seo.description || settings.defaultSeo.description;
const hasActiveHero = page.blocks.some((block) => block.status === 'active' && block.type === 'core/hero');
---

<BaseLayout title={title} description={description}>
  <header class="site-header">
    <div class="site-shell site-header__inner">
      <a class="site-brand" href="/" aria-label={`${settings.siteName} home`}>{settings.siteName}</a>
      <nav class="site-navigation" aria-label="Primary navigation">
        <ul>{navigation.primary.map((item) => <li><a href={item.href}>{item.label}</a></li>)}</ul>
      </nav>
    </div>
  </header>
  <main id="main-content" data-runtime-content>
    {!hasActiveHero && <h1 class="visually-hidden">{page.title}</h1>}
    {page.blocks.map((block) => <BlockRenderer block={block} />)}
  </main>
  <SiteFooter settings={settings} />
  <script>
    type RuntimeLink = { label: string; href: string };
    type RuntimeBlock = { status: string; type: string; content: Record<string, any> };
    type RuntimeFooter = { copyright: string; summary?: string; columns?: Array<{ id: string; title: string; links: RuntimeLink[] }>; socialLinks?: RuntimeLink[]; legalLinks?: RuntimeLink[]; supportingImages?: Array<{ src: string; alt: string; href?: string }>; newsletter?: { enabled: boolean; heading: string; description: string; actionLabel: string; actionHref?: string; privacyNote: string }; appearance?: { variant: 'light' | 'dark' | 'centered' | 'image'; backgroundImage?: string; overlay: 'none' | 'light' | 'medium' | 'strong' } };
    type RuntimeSnapshot = { page: { title: string; seo: { title: string; description: string }; blocks: RuntimeBlock[] }; settings: { siteName: string; tagline: string; defaultSeo: { titleSuffix: string; description: string }; footer: RuntimeFooter }; navigation: { primary: RuntimeLink[] } };
    const safeHref = (value: unknown): value is string => typeof value === 'string' && (value.startsWith('/') || value.startsWith('#') || value.startsWith('https://'));
    const appendLinks = (parent: HTMLElement, label: string, links: RuntimeLink[]) => { if (!links.length) return; const nav = document.createElement('nav'); nav.setAttribute('aria-label', label); const list = document.createElement('ul'); links.filter((link) => safeHref(link.href)).forEach((item) => { const li = document.createElement('li'); const link = document.createElement('a'); link.href = item.href; link.textContent = item.label; li.append(link); list.append(li); }); nav.append(list); parent.append(nav); };
    const renderContentGrid = (content: Record<string, any>) => { const section = document.createElement('section'); const layout = ['one-column', 'two-column', 'three-column', 'card-grid'].includes(content.layout) ? content.layout : 'three-column'; const surface = ['default', 'subtle', 'accent', 'dark'].includes(content.surface) ? content.surface : 'default'; const spacing = ['compact', 'default', 'spacious'].includes(content.spacing) ? content.spacing : 'default'; const alignment = content.alignment === 'center' ? 'center' : 'start'; section.className = `site-grid-section site-grid-section--${surface} site-grid-section--${spacing} site-grid-section--align-${alignment}`; const shell = document.createElement('div'); shell.className = 'site-shell'; const header = document.createElement('header'); header.className = 'site-section-heading'; if (content.eyebrow) { const eyebrow = document.createElement('p'); eyebrow.className = 'site-eyebrow'; eyebrow.textContent = content.eyebrow; header.append(eyebrow); } const heading = document.createElement('h2'); heading.textContent = content.heading; header.append(heading); if (content.introduction) { const intro = document.createElement('p'); intro.textContent = content.introduction; header.append(intro); } const grid = document.createElement('div'); grid.className = `site-content-grid site-content-grid--${layout}`; (Array.isArray(content.items) ? content.items : []).forEach((item) => { const article = document.createElement('article'); article.className = layout === 'card-grid' ? 'site-content-card' : 'site-content-item'; if (item.image && safeHref(item.image.src)) { const image = document.createElement('img'); image.src = item.image.src; image.alt = item.image.alt; image.loading = 'lazy'; article.append(image); } const body = document.createElement('div'); const itemHeading = document.createElement('h3'); itemHeading.textContent = item.heading; const paragraph = document.createElement('p'); paragraph.textContent = item.body; body.append(itemHeading, paragraph); if (item.action && safeHref(item.action.href)) { const action = document.createElement('a'); action.href = item.action.href; action.textContent = item.action.label; body.append(action); } article.append(body); grid.append(article); }); shell.append(header, grid); section.append(shell); return section; };
    const renderFooter = (settings: RuntimeSnapshot['settings']) => { const footer = document.querySelector<HTMLElement>('.site-footer'); if (!footer) return; const model = settings.footer; const appearance = model.appearance ?? { variant: 'light', overlay: 'medium' as const }; footer.className = `site-footer site-footer--${appearance.variant} site-footer--overlay-${appearance.overlay}`; footer.style.backgroundImage = appearance.variant === 'image' && safeHref(appearance.backgroundImage) ? `url(${JSON.stringify(appearance.backgroundImage)})` : ''; const content = document.createElement('div'); content.className = 'site-shell site-footer__content'; const brand = document.createElement('div'); brand.className = 'site-footer__brand'; const name = document.createElement('a'); name.className = 'site-footer__name'; name.href = '/'; name.textContent = settings.siteName; brand.append(name); if (model.summary) { const summary = document.createElement('p'); summary.textContent = model.summary; brand.append(summary); } const images = document.createElement('div'); images.className = 'site-footer__images'; (model.supportingImages ?? []).filter((image) => safeHref(image.src)).forEach((image) => { const picture = document.createElement('img'); picture.src = image.src; picture.alt = image.alt; picture.loading = 'lazy'; if (safeHref(image.href)) { const link = document.createElement('a'); link.href = image.href; link.append(picture); images.append(link); } else images.append(picture); }); if (images.childElementCount) brand.append(images); content.append(brand); (model.columns ?? []).forEach((column) => { const section = document.createElement('section'); section.className = 'site-footer__column'; const heading = document.createElement('h2'); heading.textContent = column.title; section.append(heading); appendLinks(section, column.title, column.links); content.append(section); }); if (model.newsletter?.enabled) { const section = document.createElement('section'); section.className = 'site-footer__newsletter'; const heading = document.createElement('h2'); heading.textContent = model.newsletter.heading; section.append(heading); if (model.newsletter.description) { const p = document.createElement('p'); p.textContent = model.newsletter.description; section.append(p); } if (safeHref(model.newsletter.actionHref)) { const action = document.createElement('a'); action.className = 'site-footer__action'; action.href = model.newsletter.actionHref; action.textContent = model.newsletter.actionLabel; section.append(action); } if (model.newsletter.privacyNote) { const small = document.createElement('small'); small.textContent = model.newsletter.privacyNote; section.append(small); } content.append(section); } const meta = document.createElement('div'); meta.className = 'site-shell site-footer__meta'; const copyright = document.createElement('p'); copyright.textContent = model.copyright; meta.append(copyright); appendLinks(meta, 'Social links', model.socialLinks ?? []); appendLinks(meta, 'Legal links', model.legalLinks ?? []); footer.replaceChildren(content, meta); };
    const routeSlug = location.pathname.replace(/^\/+|\/+$/g, '') || 'home';
    fetch(`/api/content/snapshot?slug=${encodeURIComponent(routeSlug)}`, { cache: 'no-store' }).then(async (response) => {
      if (response.ok) return response.json() as Promise<RuntimeSnapshot>;
      if (response.status === 404) throw new Error('not_found');
      throw new Error('unavailable');
    }).then(({ page, settings, navigation }) => {
      const brand = document.querySelector('.site-brand'); if (brand) { brand.textContent = settings.siteName; brand.setAttribute('aria-label', `${settings.siteName} home`); }
      document.title = `${page.seo.title || page.title} · ${settings.defaultSeo.titleSuffix}`;
      const description = document.querySelector('meta[name="description"]'); if (description) description.setAttribute('content', page.seo.description || settings.defaultSeo.description);
      const list = document.querySelector('.site-navigation ul'); if (list) { list.replaceChildren(...navigation.primary.filter((item) => safeHref(item.href)).map((item) => { const li = document.createElement('li'); const link = document.createElement('a'); link.textContent = item.label; link.href = item.href; if (new URL(link.href, location.origin).pathname === location.pathname) link.setAttribute('aria-current', 'page'); li.append(link); return li; })); }
      const main = document.querySelector('[data-runtime-content]'); if (main) { const activeBlocks = page.blocks.filter((block) => block.status === 'active'); const blocks = activeBlocks.map((block) => { if (block.type === 'core/hero') { const section = document.createElement('section'); section.className = 'site-hero'; section.setAttribute('aria-labelledby', 'hero-heading'); const inner = document.createElement('div'); inner.className = 'site-shell site-hero__inner'; const eyebrow = document.createElement('p'); eyebrow.className = 'site-eyebrow'; eyebrow.textContent = block.content.eyebrow || ''; const heading = document.createElement('h1'); heading.id = 'hero-heading'; heading.textContent = block.content.heading; const body = document.createElement('p'); body.className = 'site-hero__body'; body.textContent = block.content.body; inner.append(eyebrow, heading, body); if (block.content.action && safeHref(block.content.action.href)) { const action = document.createElement('a'); action.className = 'site-action'; action.href = block.content.action.href; action.textContent = block.content.action.label; inner.append(action); } section.append(inner); return section; } if (block.type === 'core/rich-text') { const section = document.createElement('section'); section.className = 'site-section'; section.id = 'content'; const inner = document.createElement('div'); inner.className = 'site-shell site-prose'; const heading = document.createElement('h2'); heading.textContent = block.content.heading; inner.append(heading, ...block.content.paragraphs.map((text: string) => { const p = document.createElement('p'); p.textContent = text; return p; })); section.append(inner); return section; } if (block.type === 'core/content-grid') return renderContentGrid(block.content); return null; }).filter((block): block is HTMLElement => block !== null); if (!activeBlocks.some((block) => block.type === 'core/hero')) { const heading = document.createElement('h1'); heading.className = 'visually-hidden'; heading.textContent = page.title; blocks.unshift(heading); } main.replaceChildren(...blocks); }
      renderFooter(settings);
    }).catch((error) => { if (error instanceof Error && error.message === 'not_found' && routeSlug !== 'home') { document.title = 'Page not found'; const main = document.querySelector('[data-runtime-content]'); if (main) { const section = document.createElement('section'); section.className = 'site-section'; const inner = document.createElement('div'); inner.className = 'site-shell site-prose'; const heading = document.createElement('h1'); heading.textContent = 'Page not found'; const body = document.createElement('p'); body.textContent = 'The requested page does not exist or is no longer published.'; const link = document.createElement('a'); link.className = 'site-action'; link.href = '/'; link.textContent = 'Return home'; inner.append(heading, body, link); section.append(inner); main.replaceChildren(section); } } /* Keep the validated static fallback when runtime services are unavailable. */ });
  </script>
</BaseLayout>
