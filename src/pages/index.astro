---
import BlockRenderer from '../components/blocks/BlockRenderer.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadHomePage, loadNavigation, loadSiteSettings } from '../services/page-loader';

const [page, settings, navigation] = await Promise.all([loadHomePage(), loadSiteSettings(), loadNavigation()]);
const title = `${page.title} · ${settings.defaultSeo.titleSuffix}`;
---

<BaseLayout title={title} description={settings.defaultSeo.description}>
  <header class="site-header">
    <div class="site-shell site-header__inner">
      <a class="site-brand" href="/" aria-label={`${settings.siteName} home`}>{settings.siteName}</a>
      <nav class="site-navigation" aria-label="Primary navigation">
        <ul>{navigation.primary.map((item) => <li><a href={item.href}>{item.label}</a></li>)}</ul>
      </nav>
    </div>
  </header>
  <main id="main-content">
    {page.blocks.map((block) => <BlockRenderer block={block} />)}
  </main>
  <footer class="site-footer"><div class="site-shell"><p>{settings.footer.copyright}</p><p>{settings.tagline}</p></div></footer>
</BaseLayout>
