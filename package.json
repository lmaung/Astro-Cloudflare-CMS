{
  "name": "astro-boilerplate-cms",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run generate && astro check && astro build",
    "build:pages": "sh scripts/prepare-content-repository.sh && npm run build",
    "preview": "astro preview",
    "check": "npm run generate:check && astro check && tsc --noEmit",
    "generate": "tsx scripts/generate-component-catalog.ts",
    "generate:check": "npm run generate && git diff --exit-code -- generated",
    "validate:content": "tsx scripts/validate-content-repository.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.1",
    "@rjsf/core": "^6.7.0",
    "@rjsf/utils": "^6.7.0",
    "@rjsf/validator-ajv8": "^6.7.0",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.3",
    "jose": "^6.2.4",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tailwindcss": "^4.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
